# Azure AI Foundry (Track A and B)
PROJECT_CONNECTION_STRING=

# Azure OpenAI (optional, if using directly instead of Foundry)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Azure AI Search (Track A - if using Search instead of File Search)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=

# Azure AI Language (Track C - sentiment analysis)
AZURE_LANGUAGE_ENDPOINT=
AZURE_LANGUAGE_KEY=

# Azure Translator (Track C - translation)
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
# AZURE_TRANSLATOR_ENDPOINT defaults to https://api.cognitive.microsofttranslator.com
